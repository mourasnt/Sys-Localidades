# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db-sys-localidades:5432/sys_localidades

# PostgreSQL (usado pelo docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sys_localidades

# Autenticação X-Token (substitua por um valor seguro)
API_TOKEN=your-token-here

# Sincronização
SYNC_IBGE_ON_STARTUP=true
